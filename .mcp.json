{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "~/src/github.com/hi120ki/model-armor-evaluator",
        "--enable-web-dashboard",
        "false",
        "--tool-timeout",
        "30"
      ],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    },
    "deepwiki": {
      "type": "stdio",
      "command": "npx",
      "args": ["mcp-remote", "https://mcp.deepwiki.com/sse"],
      "env": {}
    }
  }
}
